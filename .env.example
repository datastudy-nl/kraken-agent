# === LLM Provider Keys (at least one required) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# === Deployment ===
KRAKEN_PORT=8080
KRAKEN_API_KEY=         # Protect your API — clients must send this as Bearer token

# === Database Passwords ===
POSTGRES_PASSWORD=kraken
NEO4J_PASSWORD=kraken

# === Optional: Neo4j Browser ===
NEO4J_BROWSER_PORT=7474

# === Optional: Model Defaults ===
KRAKEN_DEFAULT_MODEL=gpt-5.4
KRAKEN_EXTRACTION_MODEL=gpt-5.4

# === Dreaming / background synthesis ===
KRAKEN_DREAM_CRON=*/15 * * * *
KRAKEN_DREAM_MESSAGE_LIMIT=200
